# ── Puro Gozo · Quiz ── copie para .env.local e preencha ──

# Link do checkout Hotmart (obrigatório em produção)
NEXT_PUBLIC_CHECKOUT_URL=https://pay.hotmart.com/XXXXXXX

# Endpoint que recebe os eventos de analytics (Supabase / Meta CAPI / etc.)
# Deixe vazio em dev — os eventos vão pro console.
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# ── Meta / Facebook ──────────────────────────────────────────
# ID do Pixel (já tem fallback no código; só preencha se mudar o Pixel)
NEXT_PUBLIC_META_PIXEL_ID=902002282309973

# Conversions API — token de acesso. ⚠️ SERVER-ONLY: NUNCA use NEXT_PUBLIC_,
# nunca comite o valor real. Gere em: Events Manager → sua fonte de dados →
# Configurações → Conversions API → Gerar token de acesso.
META_CAPI_TOKEN=

# (opcional) versão da Graph API — default v21.0
META_GRAPH_VERSION=

# (opcional) código da aba "Testar eventos" do Events Manager, p/ validar
# em teste. DEIXE VAZIO em produção.
META_TEST_EVENT_CODE=

# ── Hotmart (webhook de Purchase) ────────────────────────────
# Token (hottok) do webhook configurado na Hotmart, p/ validar as chamadas.
# Aponte o webhook da Hotmart para: https://SEU-DOMINIO/api/hotmart/webhook
HOTMART_HOTTOK=
